# Dev mode
OIDC_ISSUER_URL=http://localhost:9998
OIDC_CLIENT_ID=local-dev
OIDC_CLIENT_SECRET=dev-secret-must-be-at-least-32-chars
OIDC_REDIRECT_URI=http://localhost:5174/auth/callback
SESSION_SECRET=dev-session-secret-must-be-at-least-32-chars

# SQLite (local file instead of /db/duro.sqlite)
DURO_DB_PATH=./duro-dev.sqlite

# LLDAP
LLDAP_URL=http://localhost:17170
LLDAP_ADMIN_USER=admin
LLDAP_ADMIN_PASS=admin-password

# Vault
NAS_VAULT_ADDR=http://localhost:8200
NAS_VAULT_TOKEN=dev-token

# SMTP (dummy)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
