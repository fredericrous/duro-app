{
  "expo": {
    "name": "duro",
    "slug": "duro",
    "scheme": "duro",
    "web": {
      "output": "server"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app",
          "unstable_useServerRendering": true,
          "unstable_useServerDataLoaders": true,
          "unstable_useServerMiddleware": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
